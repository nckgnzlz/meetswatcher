# Copy this file to .env and fill in your own values. Never commit .env.

# The Google Meet link to watch. Use a recurring meeting from Google Calendar
# so the link stays the same every session (see README).
MEET_URL=https://meet.google.com/abc-defg-hij

# Your ntfy.sh topic name. Anyone who knows this string can read your
# notifications and send you fake ones, so treat it like a password:
# pick something long and unguessable, then subscribe to it in the ntfy app.
NTFY_TOPIC=pick-something-long-and-random

# Where your saved Google session lives. Created by auth_setup.py.
# The default is fine unless you want to keep it somewhere else.
AUTH_STATE_PATH=auth.json

# Run the browser invisibly (true) or in a visible window (false).
# Set to false the first time you run locally if you want to watch it work;
# keep true on a server.
HEADLESS=true

# How often, in seconds, to check the waiting room.
POLL_INTERVAL_SECONDS=5
